{
  "name": "backbrain-mc",
  "version": "0.1.0",
  "description": "Mission-style telemetry dashboard for Claude Code sessions, Backbrain notes, and git activity.",
  "author": "Kaustubh Deshpande",
  "license": "MIT",
  "keywords": [
    "claude",
    "claude-code",
    "backbrain",
    "ai",
    "telemetry",
    "dashboard",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/you/backbrain-mc.git"
  },
  "homepage": "https://github.com/you/backbrain-mc#readme",
  "bin": {
    "backbrain-mc": "./dist/backbrain-mc"
  },
  "files": [
    "dist/",
    "client/dist/",
    "scripts/",
    "config/",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run dev:server",
    "dev:server": "bun --watch server/cli.ts",
    "dev:client": "bun run --cwd client dev",
    "build:client": "bun run --cwd client build",
    "build:server": "bun build server/cli.ts --compile --outfile dist/backbrain-mc --target bun",
    "build:copy-client": "cp -r client/dist dist/client",
    "build": "bun run build:client && bun run build:server && bun run build:copy-client",
    "prepublishOnly": "bun run build",
    "install-hooks": "bun server/cli.ts install-hooks",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "workspaces": ["client"],
  "engines": {
    "bun": ">=1.0.0"
  }
}
